# window settings
window-theme = ghostty
maximize = true
window-width = 140
window-height = 35
window-padding-x = 5
window-padding-y = 5

# GTK settings
gtk-titlebar-hide-when-maximized = true

# Appearance
theme = KanagawaWave
font-family = Sudo
font-size = 13.5
adjust-cell-height = 3
cursor-style = block
shell-integration-features = no-cursor
