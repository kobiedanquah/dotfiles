{
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "project_panel": {
    "dock": "left",
  },
  "icon_theme": "Base Charmed Icons",
  "cli_default_open_behavior": "new_window",
  "helix_mode": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "base_keymap": "JetBrains",
  "ui_font_size": 17,
  "ui_font_family": "Adwaita Sans",
  "buffer_font_size": 17.0,
  "buffer_font_family": "Intel One Mono",
  "buffer_font_fallbacks": [
    "Source Code Pro"
  ],
  "buffer_line_height": {
    "custom": 1.3,
  },
  "agent_buffer_font_size": 16,
  "theme": "Kanagawa Wave",
  "disable_ai": true,
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "tabs": {
    "file_icons": true,
  },
  "preferred_line_length": 120,
  "soft_wrap": "bounded",
  "show_wrap_guides": false,
  "auto_update": false,
  "title_bar": {
    "show_sign_in": false,
  },
}